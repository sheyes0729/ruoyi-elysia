{
  "name": "@ruoyi/backend",
  "version": "0.0.1",
  "module": "src/index.js",
  "description": "基于 Elysia + Bun 重构若依后端",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/database/seed.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1",
    "@elysiajs/cors": "^1",
    "@elysiajs/jwt": "^1",
    "@elysiajs/swagger": "^1",
