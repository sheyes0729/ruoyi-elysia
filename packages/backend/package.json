    "bcryptjs": "^2",
    "csv-parse": "^5",
    "csv-stringify": "^6",
    "dayjs": "^1",
    "dotenv": "^16",
    "drizzle-orm": "^0.38",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.1",
    "ioredis": "^5",
    "mysql2": "^3",
    "pino": "^9",
    "pino-pretty": "^13",
    "prom-client": "^15.1.3",
    "request-ip": "^3.3.0",
    "svg-captcha": "^1.4",
    "xlsx": "^0.18",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@faker-js/faker": "^9",
    "@types/bcryptjs": "^2.4",
    "@types/node": "^22.13.14",
    "bun-types": "latest",
    "drizzle-kit": "^0.30",
    "eslint": "^9.23.0",
    "prettier": "^3",
    "supertest": "^7",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  }
