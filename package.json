{
  "name": "ruoyi-elysia",
  "version": "0.0.1",
  "module": "src/index.js",
  "description": "基于 Elysia + Bun 重构若依后端，提供高性能、易扩展、模块化的后台服务框架，包含认证授权、RBAC权限管理、系统管理等完整能力",
  "license": "MIT",
  "keywords": [
    "elysia",
    "bun",
    "ruoyi",
    "backend",
    "typescript",
    "rbac",
    "权限管理",
    "后台框架",
    "若依",
    "权限系统",
    "用户管理",
    "角色权限"
  ],
  "author": {
    "name": "sheyes0729",
    "email": "sheyes0729@163.com"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/database/seed.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1",
    "@elysiajs/cors": "^1",
    "@elysiajs/jwt": "^1",
    "@elysiajs/swagger": "^1",
    "@types/request-ip": "^0.0.41",
    "bcryptjs": "^2",
    "csv-parse": "^5",
    "csv-stringify": "^6",
    "dayjs": "^1",
    "dotenv": "^16",
    "drizzle-orm": "^0.38",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.1",
    "ioredis": "^5",
    "mysql2": "^3",
    "pino": "^9",
    "pino-pretty": "^13",
    "request-ip": "^3.3.0",
    "svg-captcha": "^1.4",
    "xlsx": "^0.18",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/bcryptjs": "^2.4",
    "@types/node": "^22.13.14",
    "bun-types": "latest",
    "drizzle-kit": "^0.30",
    "eslint": "^9.23.0",
    "prettier": "^3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "supertest": "^7",
    "@faker-js/faker": "^9"
  }
}
